# =============================================================
# Smart Cushion Fog Node – Environment Configuration Template
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all values marked with CHANGE_ME
#   3. NEVER commit the .env file (it is already in .gitignore)
# =============================================================

# ─── Device Identity ───────────────────────────────────────── 
# Note: The Fog node now listens to multiple ESP32 devices (e.g. esp32-1, esp32-2).
# This DEVICE_ID is used to identify the Fog Node itself when syncing to the Cloud.
DEVICE_ID=fog-node-01

# ─── Local MQTT Broker (Edge <-> Fog) ────────────────────────
# When using Docker Compose, MQTT_HOST should be the service name
MQTT_HOST=mosquitto
MQTT_PORT=1883

# Credentials for Mosquitto auth (must match mosquitto/config/passwd)
# Generate with: ./scripts/generate_mqtt_credentials.sh
MQTT_USERNAME=fognode
MQTT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# TLS for local MQTT (optional – set to true for production)
MQTT_USE_TLS=false
# Path to CA cert if TLS is enabled:
# MQTT_CA_CERT=certs/mosquitto-ca.crt

# MQTT topics (defaults match ESP32 firmware)
MQTT_TOPIC_RAW=cushion/raw
MQTT_TOPIC_CONTROL=cushion/control

# ─── WebSocket Server (Fog -> Web App) ────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8765

# Bearer token for WebSocket authentication.
# The Web App must send this in the Authorization header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave EMPTY to disable authentication (NOT recommended in production).
WS_AUTH_TOKEN=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32

# ─── AI Model ─────────────────────────────────────────────────
MODEL_PATH=ai/models/posture_model.pt

# Temperature below this value (°C) = no person detected
TEMPERATURE_THRESHOLD=30.0

# ─── Alert / Vibration Settings ──────────────────────────────
# Duration of vibration alert in milliseconds
VIBRATION_DURATION_MS=1000

# Send alert after N consecutive incorrect posture readings
INCORRECT_POSTURE_ALERT_THRESHOLD=3

# ─── Cloud Sync (AWS IoT Core) ───────────────────────────────
# Set to false during development. Enable only when AWS is configured.
CLOUD_ENABLED=false

# AWS IoT Core endpoint URL
# Example: xxxxxxxxxxxx-ats.iot.ap-northeast-1.amazonaws.com
AWS_ENDPOINT=

# Unique client ID for this fog node
AWS_CLIENT_ID=fog-node-01

# Paths to AWS IoT certificates (files must be placed in certs/ directory)
# certs/ is gitignored – download certs from AWS IoT Console
AWS_CERT_PATH=certs/certificate.pem.crt
AWS_KEY_PATH=certs/private.pem.key
AWS_CA_PATH=certs/AmazonRootCA1.pem

# MQTT topic to publish sync data
AWS_TOPIC_SYNC=cushion/sync

# How often (seconds) to sync session summary to cloud
CLOUD_SYNC_INTERVAL=60
